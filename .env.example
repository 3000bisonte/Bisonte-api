# =================== NEON POSTGRESQL CONFIGURATION ===================
# IMPORTANTE: Reemplaza los valores de ejemplo con tus credenciales reales de Neon

# Base de datos principal con PgBouncer (para la aplicación)
DATABASE_URL="postgresql://username:password@ep-xxx-xxx.us-east-1.aws.neon.tech/bisonte_logistica?sslmode=require&pgbouncer=true&connect_timeout=15"

# URL directa sin PgBouncer (para migraciones y operaciones administrativas)
DIRECT_URL="postgresql://username:password@ep-xxx-xxx.us-east-1.aws.neon.tech/bisonte_logistica?sslmode=require&connect_timeout=15"

# === OPTIMIZACIONES NEON SERVERLESS ===
PGBOUNCER_POOL_MODE="transaction"
PGBOUNCER_MAX_CLIENT_CONN=100
PGBOUNCER_DEFAULT_POOL_SIZE=25
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=5
DATABASE_QUERY_TIMEOUT=30

# =================== AUTENTICACIÓN Y SEGURIDAD ===================
# JWT Secret para autenticación móvil (mínimo 32 caracteres)
JWT_SECRET="tu-jwt-secret-super-seguro-aqui-minimo-32-caracteres-para-mayor-seguridad"

# NextAuth.js para OAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="tu-nextauth-secret-aqui"

# Google OAuth para Google Sign-In
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-google-client-secret"

# Google Identity Services (frontend)
# Usado por el botón de "Continuar con Google" (GIS) en el cliente
NEXT_PUBLIC_GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"

# =================== MERCADOPAGO CONFIGURATION ===================
# MercadoPago para pagos en la app móvil

# PRODUCCIÓN (descomenta para usar en producción)
# NEXT_PUBLIC_INIT_MERCADOPAGO="APP_USR-tu-mercadopago-public-key"
# M_P_PUBLIC_KEY="APP_USR-tu-mercadopago-access-token"

# TESTING (usa estas para desarrollo)
NEXT_PUBLIC_INIT_MERCADOPAGO="TEST-tu-mercadopago-test-public-key"
M_P_PUBLIC_KEY="TEST-tu-mercadopago-test-access-token"
NEXT_PUBLIC_URL_BRICK_STATUS_SCREEN="http://localhost:3000"

# =================== NOTIFICACIONES EMAIL ===================
# Resend API para emails transaccionales
RESEND_API_KEY="re_tu-resend-api-key-aqui"

# SMTP Alternativo (opcional)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="tu-email@gmail.com"
EMAIL_PASS="tu-contraseña-de-aplicacion"

# =================== CONFIGURACIÓN DE APLICACIÓN ===================
# Entorno y puerto
NODE_ENV="development"
PORT=3001

# URLs del servidor
NEXT_PUBLIC_API_SERVER_URL="http://localhost:3000"
NEXT_PUBLIC_APP_MODE="mobile"
NEXT_PUBLIC_ENVIRONMENT="development"
